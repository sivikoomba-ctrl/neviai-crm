generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  notes     String?
  tags      String?  // JSON array as string: '["vip","partner"]'
  aiSummary String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals        Deal[]
  interactions Interaction[]
}

model Deal {
  id        String   @id @default(cuid())
  title     String
  value     Float
  stage     String   @default("Lead")
  aiScore   Float?
  aiAdvice  String?
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interaction {
  id        String   @id @default(cuid())
  type      String
  subject   String?
  body      String?
  metadata  String?
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
